# Copy this file to .env and fill in your API key.
# The app auto-detects the provider from the key prefix:
#   sk-...   → OpenAI  (gpt-4o-mini)
#   AIza...  → Google Gemini (gemini-2.0-flash)
#
# IMPORTANT: Vite only exposes env vars prefixed with VITE_ to the browser.
# Always use VITE_API_KEY, not GEMINI_API_KEY or OPENAI_API_KEY.

GEMINI_API_KEY=your_api_key_here
